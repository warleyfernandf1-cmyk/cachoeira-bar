# Copie para .env e preencha

# Supabase → Project Settings > Database > Connection string
# Use a URL do Connection Pooler (Transaction mode, porta 6543) para serverless
DATABASE_URL=postgresql://postgres.PROJETO:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-segura

# URL do frontend no Vercel (para CORS)
FRONTEND_URL=https://SEU-PROJETO.vercel.app
